# Required: Groq API key for AI generation (free at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
# Optional: additional keys for automatic rate-limit rotation
# When GROQ_API_KEY hits 429, key 2 is tried, then 3, then 4
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=

# Optional: Mistral API key — used when a user selects Mistral as their AI provider
# and has not supplied their own BYOK key. Free tier available at console.mistral.ai
MISTRAL_API_KEY=

# Optional: OpenAI API key — used when a user selects OpenAI as their AI provider
# and has not supplied their own BYOK key. Paid API at platform.openai.com/api-keys
OPENAI_API_KEY=

# Required for auth + article storage
MONGODB_URI=mongodb://localhost:27017/article-writer
SESSION_SECRET=replace-with-64-char-hex-openssl-rand-hex-32

# Required for Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Optional: NCBI API key for higher PubMed rate limit (10 req/s vs 3 req/s)
# Register free at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# Logging level: trace | debug | info | warn | error | fatal
# Dev: debug | Prod: info
LOG_LEVEL=info

# Environment: development | test | production
NODE_ENV=development

# Encryption key for sensitive data at rest (32-char hex)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-32-char-hex

# Set automatically by CI to the current git commit SHA — leave blank locally
BUILD_SHA=

# ── Agentic RAG (Sprint 8) ────────────────────────────────────────────────────
# Pinecone vector database — required for semantic search over your paper library
# Free tier available at pinecone.io (one index, unlimited namespaces)
PINECONE_API_KEY=
# Name of the Pinecone index to use (created automatically on first ingest)
PINECONE_INDEX_NAME=article-writer
